#!/data/data/com.termux/files/usr/bin/env bash
# cvui logo — colors follow the active theme (~/.cvui/theme).

_theme="cvui"
[[ -r "$HOME/.cvui/theme" ]] && _theme=$(<"$HOME/.cvui/theme")

case "$_theme" in
  forest)
    C=$'\033[38;5;34m'   # bright green
    D=$'\033[38;5;28m'   # dark green
    O=$'\033[38;5;220m'  # gold accent
    ;;
  sky)
    C=$'\033[38;5;117m'  # sky blue
    D=$'\033[38;5;111m'  # softer blue
    O=$'\033[38;5;223m'  # warm accent
    ;;
  *)
    C=$'\033[38;5;51m'   # cyan
    D=$'\033[38;5;39m'   # blue
    O=$'\033[38;5;215m'  # orange
    ;;
esac
R=$'\033[0m'

# If the user has set a custom banner via `cvui banner <text>`, prefer it.
_cvui_HOME_GUESS="${cvui_HOME:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}"
_cvui_CUSTOM_BANNER="$_cvui_HOME_GUESS/assets/banner.txt"
if [[ -s $_cvui_CUSTOM_BANNER ]]; then
  echo
  _row=0
  while IFS= read -r _line || [[ -n $_line ]]; do
    if (( _row < 2 )); then printf '%s%s%s\n' "$C" "$_line" "$R"
    else                     printf '%s%s%s\n' "$D" "$_line" "$R"
    fi
    _row=$((_row + 1))
  done < "$_cvui_CUSTOM_BANNER"
  printf '                     %s⚡ cybervaultke • KAI UI ⚡%s\n\n' "$O" "$R"
  unset _cvui_HOME_GUESS _cvui_CUSTOM_BANNER _line _row _theme
  exit 0
fi
unset _cvui_HOME_GUESS _cvui_CUSTOM_BANNER

cat <<EOF

${C} ██╗  ██╗ █████╗ ███████╗██╗  ██╗    ███████╗██╗ ██████╗ ██╗  ██╗████████╗
${C} ██║ ██╔╝██╔══██╗██╔════╝██║  ██║    ██╔════╝██║██╔════╝ ██║  ██║╚══██╔══╝
${D} █████╔╝ ███████║███████╗███████║    ███████╗██║██║  ███╗███████║   ██║
${D} ██╔═██╗ ██╔══██║╚════██║██╔══██║    ╚════██║██║██║   ██║██╔══██║   ██║
${D} ██║  ██╗██║  ██║███████║██║  ██║    ███████║██║╚██████╔╝██║  ██║   ██║
${D} ╚═╝  ╚═╝╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝    ╚══════╝╚═╝ ╚═════╝ ╚═╝  ╚═╝   ╚═╝${R}
                     ${O}⚡ cybervaultke • KAI UI ⚡${R}

EOF
unset _theme
