#!/data/data/com.termux/files/usr/bin/env bash
# cvui — cybervaultke UI shell (JARVIS-inspired)
# https://github.com/cybervaultkeplatform/cvui

set -u

# Resolve repo root (supports symlinked install)
_self="${BASH_SOURCE[0]}"
while [[ -L $_self ]]; do _self="$(readlink "$_self")"; done
cvui_HOME="$(cd "$(dirname "$_self")/.." && pwd)"
export cvui_HOME

# shellcheck disable=SC1091
source "$cvui_HOME/lib/ui.sh"
source "$cvui_HOME/lib/voice.sh"
source "$cvui_HOME/lib/sound.sh"
source "$cvui_HOME/lib/auth.sh"
source "$cvui_HOME/lib/commands.sh"
[[ -f "$cvui_HOME/lib/banner.sh" ]] && source "$cvui_HOME/lib/banner.sh"

export cvui_VOICE="${cvui_VOICE:-1}"
export cvui_SOUNDS="${cvui_SOUNDS:-1}"

cvui::boot_sequence() {
  clear
  ui::banner           # full motd: logo + sysinfo + datetime + disk
  sound::power_on
  printf "\n${C_DIM}  initializing subsystems...${C_RESET}\n"
  local steps=(
    "loading UI kernel"
    "mounting voice module"
    "calibrating neural net"
    "handshake with tgpt"
    "authentication ready"
  )
  # Fast path: skip per-step animation when cvui_FAST_BOOT=1 (default on)
  if [[ ${cvui_FAST_BOOT:-1} -eq 1 ]]; then
    for s in "${steps[@]}"; do ui::say_status OK "$s"; done
  else
    for s in "${steps[@]}"; do
      sleep 0.18
      ui::say_status OK "$s"
      sound::beep
    done
    sleep 0.3
  fi
  echo
  # Drain any keystrokes the user typed during boot — otherwise they leak
  # into the upcoming auth prompt and trigger phantom failed logins.
  if [[ -t 0 ]]; then
    stty sane 2>/dev/null
    while IFS= read -r -t 0 -n 1000 _drain 2>/dev/null; do :; done
  fi
}

cvui::post_login() {
  clear
  ui::banner
  voice::greet
  ui::maker_intro
  printf "\n  ${C_DIM}Type ${C_RESET}${C_GREEN}help${C_RESET}${C_DIM} for commands. ${C_RESET}${C_GREEN}exit${C_RESET}${C_DIM} to leave.${C_RESET}\n\n"
}

cvui::repl() {
  local line cmd args
  while :; do
    ui::prompt_char
    IFS= read -r line || { echo; break; }
    [[ -z ${line// } ]] && continue
    cmd=${line%% *}
    if [[ $line == *" "* ]]; then args=${line#* }; else args=""; fi

    case "$cmd" in
      help|h|?)     cmd::help ;;
      about|intro)  cmd::about ;;
      ask)          cmd::ask $args ;;
      joke)         cmd::joke ;;
      meme)         cmd::meme ;;
      fact)         cmd::fact ;;
      news)         cmd::news ;;
      crypto)       cmd::crypto $args ;;
      ip)           cmd::ip ;;
      define)       cmd::define $args ;;
      weather)      cmd::weather $args ;;
      sysinfo|sys)  cmd::sysinfo ;;
      qr)           cmd::qr $args ;;
      note)         cmd::note $args ;;
      notes)        cmd::notes ;;
      todo)         cmd::todo $args ;;
      timer)        cmd::timer $args ;;
      doctor)       cmd::doctor ;;
      motd)         ui::banner ;;
      banner)       cmd::banner $args ;;
      time|date)    cmd::time ;;
      ls)           ui::ls $args ;;
      ll)           ui::ll $args ;;
      cd)           cd "${args:-$HOME}" || ui::say_status ERR "cd failed" ;;
      clear|cls)    clear; ui::banner ;;
      voice)        cmd::voice_toggle $args ;;
      theme)        cmd::theme $args ;;
      noauth)       cmd::noauth $args ;;
      update)       cmd::update ;;
      whoami)       cmd::whoami ;;
      reset-auth)   auth::reset; exit 0 ;;
      exit|quit|bye)
        voice::bye
        sound::power_off
        ui::say_status INFO "Shutting down cvui…"
        sleep 0.6
        break
        ;;
      *)
        eval "$line"
        ;;
    esac
  done
}

cvui::usage() {
  cat <<EOF
cvui — cybervaultke UI shell

USAGE:
  cvui                       Launch interactive shell (login + REPL)
  cvui ask <question...>     One-shot: ask KAI, print answer, exit
  cvui joke | fact           One-shot: joke / fact (tgpt)
  cvui news                  Top headlines (Hacker News)
  cvui crypto [coin]         Crypto price (CoinGecko)
  cvui ip                    Public IP + geo
  cvui define <word>         Dictionary lookup
  cvui weather [city]        Current weather (wttr.in)
  cvui sysinfo               System info
  cvui qr <text>             Render a terminal QR code
  cvui note <text>           Append a timestamped note
  cvui notes                 Show all notes
  cvui todo [text|done N]    Todo list
  cvui timer <minutes>       Pomodoro timer
  cvui time                 Live clock with hacker UI
  cvui calc <expr>          Calculator
  cvui bible <ref>          Bible verse lookup
  cvui apps                 List available cvui apps
  cvui doctor                Audit optional deps + cvui health
  cvui motd                  Print the motd banner
  cvui banner <text>         Build custom banner (letters/digits only)
  cvui update                Pull latest + re-run installer
  cvui theme [name]          List / switch prompt themes
  cvui noauth [on|off]       Toggle session lock (auth)

FLAGS:
  --no-voice      Start with voice muted
  --no-sounds     Disable sound effects
  --reset-auth    Clear saved credentials
  --no-auth       Skip authentication for this session
  --version, -v   Print version
  --help, -h      Print this help
EOF
}

main() {
  # Parse flags that can appear before a subcommand
  local passthrough=()
  while (( $# )); do
    case "${1:-}" in
      --version|-v) echo "cvui 0.3.0"; exit 0 ;;
      --help|-h)    cvui::usage; exit 0 ;;
      --reset-auth) auth::reset; exit 0 ;;
      --no-voice)   export cvui_VOICE=0; shift ;;
      --no-sounds)  export cvui_SOUNDS=0; shift ;;
      --no-auth)    export cvui_NO_AUTH=1; shift ;;
      *)            passthrough+=("$1"); shift ;;
    esac
  done
  set -- "${passthrough[@]:-}"

  # One-shot mode: `cvui ask ...`, `cvui joke`, etc.
  case "${1:-}" in
    ask)       shift; cmd::ask "$@"; exit $? ;;
    joke)      cmd::joke; exit $? ;;
    fact)      cmd::fact; exit $? ;;
    meme)      cmd::meme; exit $? ;;
    news)      cmd::news; exit $? ;;
    crypto)    shift; cmd::crypto "$@"; exit $? ;;
    ip)        cmd::ip; exit $? ;;
    define)    shift; cmd::define "$@"; exit $? ;;
    weather)   shift; cmd::weather "$@"; exit $? ;;
    sysinfo)   cmd::sysinfo; exit $? ;;
    qr)        shift; cmd::qr "$@"; exit $? ;;
    note)      shift; cmd::note "$@"; exit $? ;;
    notes)     cmd::notes; exit $? ;;
    todo)      shift; cmd::todo "$@"; exit $? ;;
    timer)     shift; cmd::timer "$@"; exit $? ;;
    calc)      shift; cmd::calc "$@"; exit $? ;;
    bible)     shift; cmd::bible "$@"; exit $? ;;
    apps)      cmd::apps; exit 0 ;;
    doctor)    cmd::doctor; exit $? ;;
    motd)      ui::banner; exit 0 ;;
    banner)    shift; cmd::banner "$@"; exit $? ;;
    update)    cmd::update; exit $? ;;
    theme)     shift; cmd::theme "$@"; exit $? ;;
    "")        : ;;
    *)         cvui::usage; exit 1 ;;
  esac

  # Interactive mode
  export cvui_REPL=1
  cvui::boot_sequence
  [[ ${cvui_NO_AUTH:-0} -eq 1 || -f "$HOME/.cvui/no-lock" ]] || auth::login || exit 1
  cvui::post_login
  cvui::repl
}

main "$@"
